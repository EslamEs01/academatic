# ============================================================
# Academy Dashboard Discovery Crawler — Environment Template
# ============================================================
# Copy this file to .env.crawler and fill in the credentials
# for each role before running the crawler.
#
#   cp .env.crawler.example .env.crawler
#
# NEVER commit .env.crawler to version control. It contains
# sensitive credentials and is listed in .gitignore.
# Credentials are loaded exclusively from this file at runtime;
# they are never hardcoded or logged anywhere in the codebase.
# ============================================================

ACADEMY_BASE_URL=https://academatic.online
ACADEMY_LOGIN_URL=https://academatic.online/login
ACADEMY_ADMIN_START_URL=https://academatic.online/management/home

ADMIN_USERNAME=
ADMIN_PASSWORD=

TEACHER_USERNAME=
TEACHER_PASSWORD=

FAMILY_USERNAME=
FAMILY_PASSWORD=

CRAWLER_HEADLESS=false
CRAWLER_SLOW_MODE=true
CRAWLER_PAGE_DELAY_MS=2500
CRAWLER_CLICK_DELAY_MS=1200
CRAWLER_MAX_PAGES_PER_ROLE=300
CRAWLER_MAX_SAFE_CLICKS_PER_PAGE=120
CRAWLER_RETRY_FAILED_PAGES=true
